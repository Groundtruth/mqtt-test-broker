# MQTT Configuration
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=application/{app_id}/device/{dev_eui}/event/up

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mqttdata
DB_USER=mqttuser
DB_PASSWORD=mqttpass

# Publisher Configuration
MESSAGES_PER_SECOND=1
BATCH_SIZE=10
AUTO_RESET=true

# PostgreSQL Configuration
POSTGRES_USER=mqttuser
POSTGRES_PASSWORD=mqttpass
POSTGRES_DB=mqttdata
